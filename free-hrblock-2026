<script>
function checkZip(){
  const zip=document.getElementById("zip").value.trim();
  const result=document.getElementById("zipResult");
  if(!zip||zip.length<5){result.textContent="⚠️ Enter valid ZIP";result.style.color="#ff4d4f";return;}
  const eligible=["10001","30301","90210","60601","77001"];
  result.textContent=eligible.includes(zip)?"🎉 Eligible for free filing!":"❌ Free filing may not be available";
  result.style.color=eligible.includes(zip)?"#28a745":"#ff4d4f";
}
function calcRefund(){
  const income=parseFloat(document.getElementById("income").value);
  const taxes=parseFloat(document.getElementById("taxes").value);
  const result=document.getElementById("refundResult");
  if(isNaN(income)||isNaN(taxes)){result.textContent="⚠️ Enter valid numbers";result.style.color="#ff4d4f";return;}
  const standard=14000;
  const taxable=Math.max(0,income-standard);
  const estimated=taxes-Math.max(0,taxable*0.12);
  result.textContent="💵 Estimated Refund: $"+estimated.toLocaleString();
  result.style.color="#28a745";
}
</script>

