  <!-- JS: ZIP CHECK + REFUND CALC -->
  <script>
  function quickzip() {
    const zipButton = document.querySelector('button');
    const zipInput = document.getElementById("zipquick");
    const loadingText = "Checking..."; // Text for loading state
    zipButton.disabled = true;  // Disable the button to prevent multiple clicks
    zipButton.textContent = loadingText;  // Update button text

    const zip = zipInput.value.trim();
    setTimeout(() => { // Simulate delay for loading state
      if (!zip || zip.length < 5) {
        alert("Please enter a valid ZIP code.");
        zipButton.disabled = false;
        zipButton.textContent = "✅ Check ZIP";
        return;
      }
      alert("🎉 ZIP eligible! You can file taxes free in 2026.");
      zipButton.disabled = false;
      zipButton.textContent = "✅ Check ZIP";
    }, 1500);  // Simulated delay (1.5 seconds)
  }

  function quickcalc() {
    const income = parseFloat(document.getElementById("quickincome").value);
    const taxesPaid = parseFloat(document.getElementById("quicktaxes").value);
    const refundBox = document.getElementById("quickrefund");
    if (isNaN(income) || isNaN(taxesPaid)) {
      refundBox.textContent = "Enter valid numbers!";
      return;
    }
    let refund = Math.max(0, (income * 0.12) - taxesPaid);
    refundBox.textContent = `$${refund.toLocaleString()}`;
  }
